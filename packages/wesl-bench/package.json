{
  "name": "wesl-bench",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "bin/bench.ts",
    "bench:baseline": "bin/choose_baseline.mts",
    "bench:bun": "bun --expose-gc --allow-natives-syntax bin/bench.ts",
    "bench:details": "sudo bin/bench.ts --cpu",
    "bench:profile": "node --expose-gc --inspect-brk bin/bench.ts --profile --no-html",
    "bench:validate": "node --expose-gc --allow-natives-syntax bin/bench.ts --profile --no-html",
    "browser:build": "vite build browser",
    "browser:dev": "vite browser",
    "browser:preview": "vite preview browser",
    "test": "vitest --hideSkippedTests",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:once": "vitest run",
    "typecheck": "tsgo"
  },
  "dependencies": {
    "benchforge": "^0.2.14",
    "wesl": "workspace:*",
    "wgsl_reflect": "^1.2.1"
  },
  "devDependencies": {
    "dexnode": "^1.2.2",
    "vite": "^8.0.1",
    "wesl-plugin": "workspace:x"
  }
}
