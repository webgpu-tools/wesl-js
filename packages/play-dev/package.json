{
  "name": "play-dev",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy:auth": "wrangler deploy --config auth/wrangler.toml",
    "deploy:site": "run-s build pages:deploy",
    "dev": "vite",
    "dev:auth": "wrangler dev --config auth/wrangler.toml",
    "pages:deploy": "wrangler pages deploy --project-name wgsl-play --branch main dist",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:e2e": "playwright test",
    "typecheck": "tsgo"
  },
  "dependencies": {
    "appearance-picker": "workspace:*",
    "lz-string": "^1.5.0",
    "preact": "^10.27.2",
    "wesl": "workspace:*",
    "wgsl-edit": "workspace:*",
    "wgsl-play": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260430.1",
    "@playwright/test": "^1.53.2",
    "@preact/preset-vite": "^2.10.2",
    "npm-run-all": "^4.1.5",
    "vite": "^8.0.1",
    "wesl-plugin": "workspace:x",
    "wrangler": "^4.77.0"
  },
  "editorVersion": "2026.04"
}
